{
  "manifest_version": 3,
  "name": "Motif — Quick Capture",
  "version": "1.1.0",
  "description": "Save links and quotes to Motif with one click. No cloud, no subscription — everything stays on your device.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "tabs",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "motif-capture@byant.dev"
    }
  }
}

